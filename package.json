{
  "name": "marvin-toolkit",
  "private": true,
  "version": "2.0.0-alpha.1",
  "description": "Marvin Toolkit — MCP-first Claude Code plugin marketplace (monorepo root)",
  "type": "module",
  "engines": {
    "node": ">=20"
  },
  "workspaces": [
    "packages/*",
    "plugins/*/mcp/server"
  ],
  "scripts": {
    "build": "npm run build --workspaces --if-present",
    "test": "npm run test --workspaces --if-present",
    "lint": "eslint .",
    "lint:manifests": "node scripts/lint-manifests.mjs",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "verify-dist": "node scripts/verify-dist.mjs"
  },
  "devDependencies": {
    "@eslint/js": "^9.0.0",
    "@types/node": "^20.0.0",
    "eslint": "^9.0.0",
    "eslint-config-prettier": "^9.1.0",
    "globals": "^15.0.0",
    "prettier": "^3.2.0",
    "tsup": "^8.0.0",
    "typescript": "^5.4.0",
    "typescript-eslint": "^8.0.0"
  },
  "license": "MIT"
}
