{
  "name": "@marvin-toolkit/mcp-shared",
  "version": "0.1.0",
  "private": true,
  "description": "Shared building blocks for marvin-toolkit per-pack MCP servers (prompt loader, elicit helpers, types).",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    },
    "./elicit": {
      "types": "./dist/elicit.d.ts",
      "default": "./dist/elicit.js"
    },
    "./prompts": {
      "types": "./dist/prompts.d.ts",
      "default": "./dist/prompts.js"
    },
    "./types": {
      "types": "./dist/types.d.ts",
      "default": "./dist/types.js"
    }
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "test": "node --test test/*.test.mjs"
  },
  "engines": {
    "node": ">=20"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.0.0",
    "zod": "^3.23.0"
  },
  "devDependencies": {
    "typescript": "^6.0.3",
    "@types/node": "^20.0.0"
  }
}
