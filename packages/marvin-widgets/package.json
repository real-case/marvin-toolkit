{
  "name": "@marvin-toolkit/widgets",
  "version": "0.8.1",
  "private": true,
  "description": "MCP Apps widgets for the marvin plugin (ADR-0024) — React ui:// documents built to self-contained HTML the server serves as ui:// resources.",
  "type": "module",
  "scripts": {
    "build": "for w in src/widgets/*/; do WIDGET=$(basename \"$w\") vite build || exit 1; done",
    "test": "vitest run",
    "storybook": "storybook dev -p 6006 --no-open",
    "build-storybook": "storybook build",
    "test-storybook": "test-storybook",
    "test-storybook:update": "test-storybook -u"
  },
  "dependencies": {
    "@modelcontextprotocol/ext-apps": "^1.7.4",
    "preact": "^10.29.7"
  },
  "devDependencies": {
    "@modelcontextprotocol/sdk": "^1.29.0",
    "@preact/preset-vite": "^2.9.0",
    "@storybook/addon-toolbars": "^8.6.18",
    "@storybook/react": "^8.6.0",
    "@storybook/react-vite": "^8.6.0",
    "@storybook/test-runner": "^0.22.0",
    "@testing-library/dom": "^10.4.0",
    "@testing-library/preact": "^3.2.4",
    "@types/jest-image-snapshot": "^6.4.1",
    "@vitejs/plugin-react": "^4.3.0",
    "happy-dom": "^20.10.6",
    "jest-image-snapshot": "^6.5.2",
    "storybook": "^10.5.2",
    "typescript": "^5.4.0",
    "vite": "^5.4.0",
    "vite-plugin-singlefile": "^2.0.0",
    "vitest": "^2.1.0"
  }
}
