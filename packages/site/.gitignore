# Astro build output + generated types — regenerated, never committed.
dist/
.astro/

# Live widget-demo assets — copies of the committed plugins/marvin/widgets/*.html plus each
# widget's fixture as JSON, emitted by scripts/gen-widget-demos.mjs on every dev/build (spec 011).
# Derived from committed plugin sources, so versioning them here would duplicate ~2.7 MB.
public/widget-demos/

# Pipeline-tour terminal recordings — one asciicast per stage plus a copy of the player's vendor
# stylesheet, emitted by scripts/gen-casts.mjs on every dev/build (spec 012). Derived entirely from
# the authored scripts in that generator, which IS the versioned source. The manifest they produce
# (src/data/casts.json) is committed; these playback assets are not.
public/casts/

# dependencies
node_modules/

# Playwright artifacts
test-results/
playwright-report/
