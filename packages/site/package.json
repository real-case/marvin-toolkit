{
  "name": "@marvin-toolkit/site",
  "version": "0.9.0",
  "private": true,
  "description": "Marketing + reference site for the marvin plugin — static Astro site (website Phase 1 scaffold).",
  "type": "module",
  "engines": {
    "node": ">=22.12.0"
  },
  "scripts": {
    "gen:catalog": "node scripts/gen-catalog.mjs",
    "gen:demos": "node scripts/gen-widget-demos.mjs",
    "gen:casts": "node scripts/gen-casts.mjs",
    "gen:og": "node scripts/gen-og.mjs",
    "gen": "npm run gen:catalog && npm run gen:demos && npm run gen:casts",
    "predev": "npm run gen",
    "dev": "astro dev",
    "prebuild": "npm run gen",
    "build": "node scripts/build.mjs",
    "preview": "astro preview",
    "check:catalog": "tsc -p tsconfig.check.json",
    "pretest": "npm run check:catalog",
    "test": "node --test test/*.test.mjs",
    "test:e2e": "playwright test"
  },
  "dependencies": {
    "@astrojs/preact": "^6.0.1",
    "@fontsource-variable/hanken-grotesk": "^5.3.0",
    "@fontsource-variable/jetbrains-mono": "^5.3.0",
    "asciinema-player": "^3.17.0",
    "astro": "^7.1.1",
    "preact": "^10.29.7"
  },
  "devDependencies": {
    "@playwright/test": "^1.61.1",
    "@types/node": "^26.1.1",
    "typescript": "^5.4.0"
  }
}
