---
// Footer.astro (spec 004, F8) — the global footer (FR-1): repository, releases,
// GitHub docs, MIT license, and the author link, plus the analytics-disclosure slot.
// The disclosure states the site's cookieless Vercel Web Analytics (spec 015, F11 — FR-22):
// no cookies and no consent banner. Analytics reports only from the Vercel deployment.
const REPO = "https://github.com/real-case/marvin-toolkit";
const AUTHOR = "https://github.com/real-case";
const year = new Date().getFullYear();

const links = [
  { href: REPO, label: "Repository" },
  { href: `${REPO}/releases`, label: "Releases" },
  { href: `${REPO}/tree/main/docs`, label: "Docs" },
  { href: `${REPO}/blob/main/LICENSE`, label: "MIT License" },
  { href: AUTHOR, label: "Author" },
];
---

<footer class="footer">
  <div class="container footer__inner">
    <nav class="footer__links" aria-label="Footer">
      {
        links.map((l) => (
          <a href={l.href} rel="noopener">
            {l.label}
          </a>
        ))
      }
    </nav>
    <p class="footer__meta">
      <span>© {year} Marvin toolkit · MIT</span>
      <span class="footer__analytics" data-slot="analytics-disclosure">
        Privacy-friendly analytics · no cookies.
      </span>
    </p>
  </div>
</footer>

<style>
  .footer {
    margin-top: 6rem;
    border-top: 1px solid var(--bd);
    background: var(--srf);
  }

  .footer__inner {
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    justify-content: space-between;
    gap: 1rem;
    padding-block: 2rem;
  }

  .footer__links {
    display: flex;
    flex-wrap: wrap;
    gap: 1.25rem;
  }

  .footer__links a {
    color: var(--t2);
    font-size: 0.875rem;
  }

  .footer__links a:hover {
    color: var(--t1);
    text-decoration: none;
  }

  .footer__meta {
    display: flex;
    flex-wrap: wrap;
    gap: 1rem;
    font-size: 0.8125rem;
    color: var(--t3);
  }
</style>
